# Development image for the AniOS React console: Vite dev server with hot reload.
FROM node:22-alpine

WORKDIR /app

# The dev container only serves Vite; it never runs Playwright, so skip the
# Chromium download its postinstall would otherwise pull.
ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

# Install dependencies first so they cache independently of source edits.
# npm install (not ci) tolerates the repo lockfile drift for this dev image.
COPY package.json package-lock.json ./
RUN npm install --no-audit --no-fund

# Copy the source as a fallback; Compose bind-mounts the working tree over this
# at runtime, and an anonymous volume keeps this image's node_modules in place.
COPY . .

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
