    AgentManager --> Short
    AgentManager --> Agent
    ConversationRepo --> Conversation
    ToolService --> Tools

    Personal --> VectorPolicy
    Agent --> VectorPolicy
    Conversation --> Literal
    Tools --> VectorPolicy
    Short --> Literal
    VectorPolicy --> Literal
    Literal --> Context

    PersonalService --> Embeddings
    AgentManager --> Embeddings
    ToolService --> Embeddings
    Embeddings --> Database
    Short --> Database
    Personal --> Database
    Agent --> Database
    Conversation --> Database
    Tools --> Database

    MaintenanceCLI --> Retention
    MaintenanceCLI --> Reembed
    MaintenanceCLI --> Dimension
    MaintenanceCLI --> Operations
    APIs --> Control
    Retention --> Database
    Reembed --> Embeddings
    Reembed --> Database
    Dimension --> Database
    Operations --> Database
    Control --> Database

