SECRET_KEY=replace-with-a-local-development-secret
AUTH_REQUIRED=false
DEBUG=false

POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=anios_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_USE_NULL_POOL=false

LLM_BASE_URL=http://127.0.0.1:1234
LLM_MODEL=google/gemma-4-12b
LLM_TIMEOUT_SECONDS=120
LLM_REASONING_EFFORT=none
EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
EMBEDDING_MODEL_VERSION=nomic-embed-text-v1.5
EMBEDDING_DIMENSION=768
EMBEDDING_MAX_CONCURRENCY=1
MEMORY_SEMANTIC_MAX_COSINE_DISTANCE=0.35
MEMORY_SEMANTIC_MAX_RESULTS=5
MEMORY_SEMANTIC_MAX_CONTENT_CHARS=4000
CONVERSATION_HISTORY_TURNS=10
CONVERSATION_SUMMARY_INTERVAL=10

IMAGE_PROVIDER_BASE_URL=http://127.0.0.1:8188
IMAGE_PROVIDER_NAME=comfyui
IMAGE_MODEL=hidream_o1_image_dev_fp8_scaled.safetensors
IMAGE_PROVIDER_TIMEOUT_SECONDS=600
IMAGE_PROVIDER_POLL_SECONDS=0.5
IMAGE_MAX_CONCURRENCY=1
ARTIFACT_STORAGE_ROOT=data/artifacts
IMAGE_MAX_UPLOAD_BYTES=10485760
IMAGE_MAX_OUTPUT_BYTES=41943040
IMAGE_MAX_PIXELS=20000000
VISION_MODEL=google/gemma-4-12b
VISION_MAX_TOKENS=512
# Prior question/answer pairs replayed to the VLM for image followup questions.
VISION_THREAD_CONTEXT_TURNS=8
# Total question/answer pairs retained in one image's stored analysis thread.
VISION_THREAD_MAX_STORED=40

# Host path to your existing ComfyUI install (mounted into the comfyui container)
COMFYUI_HOST_PATH=E:/AI/ComfyUI

# Web search (Tavily). Leave SEARCH_API_KEY empty to disable search entirely.
# Free tier: 1,000 searches/month, no credit card. Key format: tvly-...
SEARCH_PROVIDER_NAME=mcp
SEARCH_BASE_URL=https://api.tavily.com
SEARCH_API_KEY=
SEARCH_MAX_RESULTS=5
SEARCH_TIMEOUT_SECONDS=15
SEARCH_MAX_CONTENT_CHARS=2000
SEARCH_DEPTH=basic
SEARCH_MCP_SERVER_ID=internet
SEARCH_MCP_TOOL_NAME=search_web

# MCP servers to discover tools from. Pin exact versions: "npx -y pkg" resolves
# to whatever is published at that moment, which is the rug-pull vector.
# Example: [{"server_id":"drive","command":"npx.cmd","args":["-y","@modelcontextprotocol/server-gdrive@1.0.0"],"risk_classification":"untrusted"}]
MCP_SERVERS_JSON=[{"server_id":"local_utility","command":"python","args":["-m","backend.mcp.servers.local_utility"],"risk_classification":"read_only"},{"server_id":"internet","command":"python","args":["-m","backend.mcp.servers.internet"],"inherit_env":["SEARCH_API_KEY","SEARCH_BASE_URL","SEARCH_MAX_RESULTS","SEARCH_TIMEOUT_SECONDS","SEARCH_MAX_CONTENT_CHARS","SEARCH_MIN_SCORE","SEARCH_DEPTH"],"risk_classification":"read_only"},{"server_id":"local_visual","transport":"http","url":"http://local-capabilities:8001/mcp","forward_context":true,"risk_classification":"untrusted"}]
MCP_LIST_TIMEOUT_SECONDS=30
TOOL_SEARCH_MAX_COSINE_DISTANCE=0.45
TOOL_SEARCH_MAX_RESULTS=5

# HTTP-transport MCP server example (sibling container or remote vendor):
# MCP_SERVERS_JSON=[{"server_id":"drive","transport":"http","url":"http://mcp-gdrive:8080/mcp","headers":{"authorization":"Bearer ..."},"risk_classification":"untrusted"}]
# Built-in read-only internet MCP server (set SEARCH_PROVIDER_NAME=mcp):
# MCP_SERVERS_JSON=[{"server_id":"internet","command":"python","args":["-m","backend.mcp.servers.internet"],"inherit_env":["SEARCH_API_KEY","SEARCH_BASE_URL","SEARCH_MAX_RESULTS","SEARCH_TIMEOUT_SECONDS","SEARCH_MAX_CONTENT_CHARS","SEARCH_MIN_SCORE","SEARCH_DEPTH"],"risk_classification":"read_only"}]
# Local utility plus internet example for Gemma tool selection and MCP search:
# MCP_SERVERS_JSON=[{"server_id":"local_utility","command":"python","args":["-m","backend.mcp.servers.local_utility"],"risk_classification":"read_only"},{"server_id":"internet","command":"python","args":["-m","backend.mcp.servers.internet"],"inherit_env":["SEARCH_API_KEY","SEARCH_BASE_URL","SEARCH_MAX_RESULTS","SEARCH_TIMEOUT_SECONDS","SEARCH_MAX_CONTENT_CHARS","SEARCH_MIN_SCORE","SEARCH_DEPTH"],"risk_classification":"read_only"}]
# Existing visual services as agent-facing FastMCP tools (Compose hostname):
# MCP_SERVERS_JSON=[{"server_id":"local_visual","transport":"http","url":"http://local-capabilities:8001/mcp","forward_context":true,"risk_classification":"untrusted"}]
