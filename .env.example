SECRET_KEY=replace-with-a-local-development-secret
AUTH_REQUIRED=false
DEBUG=false

POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=anios_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_USE_NULL_POOL=false

LLM_BASE_URL=http://127.0.0.1:1234
LLM_MODEL=google/gemma-4-12b
LLM_TIMEOUT_SECONDS=120
LLM_REASONING_EFFORT=none
EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
EMBEDDING_MODEL_VERSION=nomic-embed-text-v1.5
EMBEDDING_DIMENSION=768
EMBEDDING_MAX_CONCURRENCY=1
MEMORY_SEMANTIC_MAX_COSINE_DISTANCE=0.35
MEMORY_SEMANTIC_MAX_RESULTS=5
MEMORY_SEMANTIC_MAX_CONTENT_CHARS=4000
CONVERSATION_HISTORY_TURNS=10
CONVERSATION_SUMMARY_INTERVAL=10

IMAGE_PROVIDER_BASE_URL=http://127.0.0.1:8188
IMAGE_PROVIDER_NAME=comfyui
IMAGE_MODEL=hidream_o1_image_dev_fp8_scaled.safetensors
IMAGE_PROVIDER_TIMEOUT_SECONDS=600
IMAGE_PROVIDER_POLL_SECONDS=0.5
IMAGE_MAX_CONCURRENCY=1
ARTIFACT_STORAGE_ROOT=data/artifacts
IMAGE_MAX_UPLOAD_BYTES=10485760
IMAGE_MAX_OUTPUT_BYTES=41943040
IMAGE_MAX_PIXELS=20000000
VISION_MODEL=google/gemma-4-12b
VISION_MAX_TOKENS=512
